# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True

# Database engine: 'sqlite' (default) or 'postgresql'
DB_ENGINE=postgresql

# PostgreSQL Database Settings (if not using DATABASE_URL)
DB_NAME=recipeapp_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Alternatively, platforms like Render provide a single DATABASE_URL connection string.
# You can use that instead of the individual DB_* settings. Example:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DB_NAME
# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=True

# PostgreSQL Database Settings
DB_NAME=recipeapp_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432

# Scraper Service — LLM Fallback Parser
# Provider: 'claude' (default) or 'openai'
LLM_PROVIDER=claude
# Claude model to use (ignored if LLM_PROVIDER=openai)
LLM_MODEL=claude-haiku-4-5-20251001
# Required if LLM_PROVIDER=claude
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Required if LLM_PROVIDER=openai
OPENAI_API_KEY=your-openai-api-key-here

# Security: Lakera Guard prompt injection detection (copilot-service and scraper-service)
# Get a free API key at https://platform.lakera.ai
LAKERA_GUARD_API_KEY=your-lakera-guard-api-key-here
